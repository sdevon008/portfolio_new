rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio documents (e.g., portfolio/devendra)
    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin config document (admin/config)
    match /admin/config {
      allow read: if true;
      allow write: if true;
    }
  }
}
